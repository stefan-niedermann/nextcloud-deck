<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?><?import org.kordamp.ikonli.javafx.FontIcon?><?import it.niedermann.nextcloud.deck.javafx.ui.controller.views.SubmitTextField?><?import javafx.scene.control.Tab?><?import javafx.scene.control.TabPane?><?import javafx.scene.control.Button?><?import javafx.scene.layout.FlowPane?><?import one.jpro.platform.mdfx.MarkdownView?><?import javafx.scene.control.ToggleButton?><?import javafx.scene.control.ButtonBar?><?import javafx.geometry.* ?><?import javafx.scene.layout.* ?><?import javafx.geometry.Insets?><?import javafx.scene.control.ButtonBar?><?import javafx.scene.control.Button?><?import javafx.scene.control.TextField?><?import javafx.scene.control.TextArea?><?import javafx.scene.control.Label?><?import javafx.scene.control.TextField?><?import javafx.scene.control.ListView?><?import javafx.scene.image.Image?><?import javafx.scene.layout.GridPane?><?import javafx.scene.layout.VBox?><?import com.dlsc.gemsfx.TagsField?><?import com.dlsc.gemsfx.CalendarPicker?><?import com.dlsc.gemsfx.TimePicker?><?import com.dlsc.gemsfx.SearchField?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1" fitToHeight="true" fitToWidth="true" minWidth="300"
    stylesheets="css/features/EditCardFeature.css" xmlns="http://javafx.com/javafx/24.0.1"
    fx:controller="it.niedermann.nextcloud.deck.javafx.ui.controller.features.EditCardFeature"
    fx:id="editCardScrollpane">
    <VBox>

        <VBox styleClass="title">
            <TextField promptText="Title" fx:id="title" />
        </VBox>

        <TabPane VBox.vgrow="ALWAYS">
            <tabs>
                <Tab closable="false" text="Details">
                    <graphic>
                        <FontIcon iconLiteral="fltral-home-16" />
                    </graphic>
                    <content>
                        <VBox>

                            <FlowPane hgap="10" vgap="10">
                                <Label styleClass="label-secondary" fx:id="createdAt" />
                                <Label styleClass="label-secondary" fx:id="editedAt" />
                            </FlowPane>

                            <TagsField promptText="Labels" fx:id="labels" />

                            <TagsField promptText="Assignees" fx:id="assignees" />

                            <HBox>
                                <CalendarPicker HBox.hgrow="ALWAYS" promptText="Start date"
                                    fx:id="startDateDate" />
                                <TimePicker promptText="Start time" fx:id="startDateTime" />
                            </HBox>

                            <HBox>
                                <CalendarPicker HBox.hgrow="ALWAYS" promptText="Due date"
                                    fx:id="dueDateDate" />
                                <TimePicker promptText="Due time" fx:id="dueDateTime" />
                            </HBox>

                            <SearchField promptText="Dependent cards" fx:id="dependentCards" />

                            <ToggleButton
                                accessibleHelp="Render the markdown content of the description field"
                                accessibleText="Preview" alignment="CENTER_RIGHT"
                                fx:id="descriptionEditModeToggleButton">
                                <graphic>
                                    <FontIcon iconLiteral="fltfal-eye-show-16" iconSize="16" />
                                </graphic>
                            </ToggleButton>

                            <TextArea VBox.vgrow="ALWAYS" prefRowCount="10" promptText="Description"
                                wrapText="true" fx:id="descriptionEditor" />

                            <MarkdownView VBox.vgrow="ALWAYS" managed="false" visible="false"
                                fx:id="descriptionPreview" />

                        </VBox>
                    </content>
                </Tab>
                <Tab closable="false" text="Attachments">
                    <graphic>
                        <FontIcon iconLiteral="fltfal-attach-16" />
                    </graphic>
                    <content>
                        <VBox>
                            <ListView VBox.vgrow="ALWAYS" fx:id="attachments" />
                        </VBox>
                    </content>
                </Tab>
                <Tab closable="false" text="Comments">
                    <graphic>
                        <FontIcon iconLiteral="fltral-comment-16" />
                    </graphic>
                    <content>
                        <VBox>
                            <ListView VBox.vgrow="ALWAYS" fx:id="comments" />
                            <SubmitTextField iconLiteral="fltfal-arrow-up-24"
                                promptText="Add comment" fx:id="addComment" />
                        </VBox>
                    </content>
                </Tab>
                <Tab closable="false" text="Activity">
                    <graphic>
                        <FontIcon iconLiteral="fltral-flash-on-20" />
                    </graphic>
                    <content>
                        <VBox>
                            <ListView VBox.vgrow="ALWAYS" fx:id="activities" />
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>

        <ButtonBar>
            <buttons>
                <Button ButtonBar.buttonData="OK_DONE" text="Save" fx:id="saveBtn" />
                <Button ButtonBar.buttonData="CANCEL_CLOSE" text="Cancel" fx:id="cancelBtn" />
            </buttons>
        </ButtonBar>
    </VBox>
</ScrollPane>
