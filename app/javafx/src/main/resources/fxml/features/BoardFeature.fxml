<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?><?import javafx.geometry.Insets?><?import it.niedermann.nextcloud.deck.javafx.ui.controller.views.EmptyContentView?><?import javafx.scene.layout.StackPane?><?import com.dlsc.gemsfx.CircleProgressIndicator?><?import javafx.scene.control.Button?><?import javafx.scene.control.ListView?><?import javafx.scene.layout.BorderPane?><?import javafx.scene.layout.FlowPane?><?import javafx.scene.layout.GridPane?><?import javafx.scene.layout.HBox?><?import javafx.scene.layout.VBox?><?import javafx.scene.control.Label?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1" fitToHeight="true" fitToWidth="true" minWidth="300"
    stylesheets="css/features/BoardFeature.css" xmlns="http://javafx.com/javafx/24.0.1">
    <VBox>
        <StackPane VBox.vgrow="ALWAYS" alignment="CENTER">
            <CircleProgressIndicator maxHeight="70" maxWidth="70" progress="-1.0"
                fx:id="progress" />
            <EmptyContentView VBox.vgrow="ALWAYS" actionLabel="Add column +"
                description="Create at least one column to add cards." managed="false"
                title="No columns" visible="false" fx:id="emptyContentView" />
            <HBox VBox.vgrow="ALWAYS" managed="false" visible="false" fx:id="columns" />
        </StackPane>
    </VBox>
</ScrollPane>
