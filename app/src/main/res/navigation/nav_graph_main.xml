<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph_main"
    app:startDestination="@id/nav_graph_upcoming_cards">

    <include app:graph="@navigation/nav_graph_upcoming_cards" />
    <include app:graph="@navigation/nav_graph_view_board" />
    <include app:graph="@navigation/nav_graph_about" />

    <action
        android:id="@id/nav_graph_upcoming_cards"
        app:destination="@id/nav_graph_upcoming_cards" />

    <action
        android:id="@id/nav_graph_about"
        app:destination="@id/nav_graph_about" />

    <action
        android:id="@id/nav_graph_view_board"
        app:destination="@id/nav_graph_view_board">
        <argument
            android:name="id"
            app:argType="long"
            app:nullable="false" />
    </action>

</navigation>
